#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <SDL2/SDL.h>
#include <SDL2/SDL_mixer.h>

struct Song {
    char name[100];
    char path[200];
    struct Song* next;
    struct Song* prev;
};

struct Song* head = NULL;
struct Song* current = NULL;

// Add song
void addSong(char name[], char path[]) {
    struct Song* newSong = (struct Song*)malloc(sizeof(struct Song));
    strcpy(newSong->name, name);
    strcpy(newSong->path, path);
    newSong->next = NULL;
    newSong->prev = NULL;

    if (head == NULL) {
        head = newSong;
        current = head;
    } else {
        struct Song* temp = head;
        while (temp->next != NULL)
            temp = temp->next;
        temp->next = newSong;
        newSong->prev = temp;
    }
}

// Display playlist
void displaySongs() {
    struct Song* temp = head;
    int i = 1;
    printf("\n🎧 Playlist:\n");
    while (temp != NULL) {
        printf("%d. %s\n", i++, temp->name);
        temp = temp->next;
    }
}

// Play song
void playSong() {
    if (current == NULL) {
        printf("No song selected!\n");
        return;
    }

    Mix_Music *music = Mix_LoadMUS(current->path);
    if (!music) {
        printf("Error loading file\n");
        return;
    }

    Mix_PlayMusic(music, 1);
    printf("▶️ Playing: %s\n", current->name);
}

// Next song
void nextSong() {
    if (current && current->next) {
        current = current->next;
        playSong();
    } else {
        printf("No next song!\n");
    }
}

// Previous song
void prevSong() {
    if (current && current->prev) {
        current = current->prev;
        playSong();
    } else {
        printf("No previous song!\n");
    }
}

// Pause / Resume
void pauseResume() {
    if (Mix_PlayingMusic()) {
        if (Mix_PausedMusic()) {
            Mix_ResumeMusic();
            printf("▶️ Resumed\n");
        } else {
            Mix_PauseMusic();
            printf("⏸ Paused\n");
        }
    }
}

int main() {
    int choice;
    char name[100], path[200];

    SDL_Init(SDL_INIT_AUDIO);
    Mix_OpenAudio(44100, MIX_DEFAULT_FORMAT, 2, 2048);

    while (1) {
        printf("\n🎵 Music Player\n");
        printf("1. Add Song\n");
        printf("2. Show Playlist\n");
        printf("3. Play\n");
        printf("4. Next ⏭\n");
        printf("5. Previous ⏮\n");
        printf("6. Pause/Resume ⏯\n");
        printf("7. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter song name: ");
                scanf(" %[^\n]", name);
                printf("Enter file path: ");
                scanf(" %[^\n]", path);
                addSong(name, path);
                break;

            case 2:
                displaySongs();
                break;

            case 3:
                playSong();
                break;

            case 4:
                nextSong();
                break;

            case 5:
                prevSong();
                break;

            case 6:
                pauseResume();
                break;

            case 7:
                Mix_CloseAudio();
                SDL_Quit();
                exit(0);

            default:
                printf("Invalid choice!\n");
        }
    }
}
